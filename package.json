{
  "name": "voctrum",
  "version": "2.0.2",
  "description": "Voctrum workspace employee portal.",
  "main": "index.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "release": "dotenv -- npx electron-builder --publish always",
    "dev:release": "dotenv -- npx electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "asar": true,
    "appId": "com.voctrum.employees",
    "productName": "Voctrum Workspace",
    "publish": [
      {
        "provider": "github",
        "owner": "MohammadIqram",
        "repo": "voctrumapp"
      }
    ],
    "files": [
      "index.js",
      "preload.js",
      "components/**/*",
      "assets/logo.png",
      "package.json",
      "!**/node_modules/*/{CHANGELOG,README,readme,README.md,test,tests,Examples,examples}*",
      "!**/*.map",
      "!.git/**/*",
      "!.vscode/**/*",
      "!setup/**/*"
    ],
    "directories": {
      "output": "setup"
    },
    "mac": {
      "category": "com.voctrum.employees",
      "icon": "assets/logo.png"
    },
    "win": {
      "icon": "assets/logo.png",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "Voctrum-${version}-${arch}.exe",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "linux": {
      "icon": "assets/logo.png",
      "target": [
        "AppImage",
        "tar.gz"
      ]
    }
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "electron": "^34.0.1",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
